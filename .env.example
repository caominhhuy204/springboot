DB_PORT=3306
DB_NAME=mydb
DB_USERNAME=root
DB_PASSWORD=123456
MYSQL_ROOT_PASSWORD=123456
DB_USE_SSL=false

JWT_SECRET=replace_with_a_long_random_secret
